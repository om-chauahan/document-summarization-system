# Copy this file to `.env` and fill in your own values.
# IMPORTANT: `.env` must NOT be committed to git.

# -----------------------------
# Frontend
# -----------------------------
# Used by Vite to call the Django API.
VITE_API_BASE=http://localhost:8000

# Used by Django to redirect back to the SPA after OAuth.
DSS_FRONTEND_BASE=http://localhost:5173

# -----------------------------
# Google OAuth (server-side)
# -----------------------------
# Create these in Google Cloud Console → APIs & Services → Credentials.
DSS_GOOGLE_CLIENT_ID=
DSS_GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI in Google Cloud Console.
DSS_GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/

# -----------------------------
# Razorpay (optional)
# -----------------------------
DSS_RAZORPAY_KEY_ID=
DSS_RAZORPAY_KEY_SECRET=

# -----------------------------
# Ollama (optional)
# -----------------------------
# DSS_OLLAMA_MODEL=mistral
# DSS_OLLAMA_HOST=http://localhost:11434
# DSS_OLLAMA_MAX_CHARS=12000

